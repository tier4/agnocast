<launch>
    <node_container pkg="agnocastlib" exec="agnocast_component_container" name="no_rclcpp_composable_listener_container" namespace="" output="screen">
      <env name="LD_PRELOAD" value="libagnocast_heaphook.so:$(env LD_PRELOAD '')" />

      <composable_node pkg="agnocast_sample_application" plugin="NoRclcppComposableSubscriber" name="no_rclcpp_composable_listener_node" namespace="">
        <param name="topic_name" value="/my_topic" />
        <param name="queue_size" value="10" />
      </composable_node>
    </node_container>
</launch>
