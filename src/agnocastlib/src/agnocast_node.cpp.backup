  return false;
}

bool Node::load_parameters_from_yaml_file(const std::string & file_path)
{
  // Corresponds to rcl_parse_yaml_file in rcl_yaml_param_parser/src/parser.c
  // Parses YAML files with the standard ROS 2 parameter format:
  //   /**:
  //     ros__parameters:
  //       param_name: value
  // or for a specific node:
  //   /node_name:
  //     ros__parameters:
  //       param_name: value

  FILE * file = fopen(file_path.c_str(), "r");
  if (!file) {
    return false;
  }

  yaml_parser_t parser;
  yaml_event_t event;

  if (!yaml_parser_initialize(&parser)) {
    fclose(file);
    return false;
  }

  yaml_parser_set_input_file(&parser, file);

  // State machine for parsing ROS 2 parameter YAML
  // YAML structure:
  //   /node_name:              <- IN_NODE_MAP (scalar)
  //     ros__parameters:       <- IN_NODE_CONTENT (scalar key)
  //       param_name: value    <- IN_PARAMS_MAP
  enum class ParseState
  {
    START,
    IN_DOCUMENT,
    IN_NODE_MAP,         // Top-level mapping containing node names
    IN_NODE_CONTENT,     // Inside a node's mapping, looking for ros__parameters
    AWAITING_PARAMS_MAP, // Saw ros__parameters key, waiting for its mapping
    IN_PARAMS_MAP,       // Inside ros__parameters mapping
    EXPECT_PARAM_VALUE   // Saw parameter name, expecting value
  };

  ParseState state = ParseState::START;
  std::string current_node_name;
  std::string current_param_name;
  int map_depth = 0;
  int skip_depth = 0;  // For skipping nested structures
  bool done = false;
  bool success = true;

  while (!done) {
    if (!yaml_parser_parse(&parser, &event)) {
      success = false;
      break;
    }

    switch (event.type) {
      case YAML_STREAM_START_EVENT:
        break;

      case YAML_STREAM_END_EVENT:
        done = true;
        break;

      case YAML_DOCUMENT_START_EVENT:
        state = ParseState::IN_DOCUMENT;
        break;

      case YAML_DOCUMENT_END_EVENT:
        state = ParseState::START;
        break;

      case YAML_MAPPING_START_EVENT:
        if (state == ParseState::IN_DOCUMENT) {
          // Top-level mapping - contains node names
          state = ParseState::IN_NODE_MAP;
        } else if (state == ParseState::IN_NODE_MAP) {
          // Entering a node's content mapping (after node name scalar)
          state = ParseState::IN_NODE_CONTENT;
        } else if (state == ParseState::AWAITING_PARAMS_MAP) {
          // This is the ros__parameters mapping
          state = ParseState::IN_PARAMS_MAP;
          map_depth = 1;
        } else if (state == ParseState::IN_PARAMS_MAP) {
          map_depth++;
        } else if (state == ParseState::EXPECT_PARAM_VALUE) {
          // Parameter value is a nested mapping, skip it
          skip_depth = 1;
        }
        break;

      case YAML_MAPPING_END_EVENT:
        if (skip_depth > 0) {
          skip_depth--;
          if (skip_depth == 0) {
            current_param_name.clear();
            state = ParseState::IN_PARAMS_MAP;
          }
        } else if (state == ParseState::IN_PARAMS_MAP) {
          map_depth--;
          if (map_depth == 0) {
            state = ParseState::IN_NODE_CONTENT;
          }
        } else if (state == ParseState::IN_NODE_CONTENT) {
          state = ParseState::IN_NODE_MAP;
        } else if (state == ParseState::IN_NODE_MAP) {
          state = ParseState::IN_DOCUMENT;
        }
        break;

      case YAML_SCALAR_EVENT: {
        if (skip_depth > 0) {
          break;  // Skip scalars inside nested structures
        }

        std::string value(reinterpret_cast<char *>(event.data.scalar.value));

        if (state == ParseState::IN_NODE_MAP) {
          // This is a node name (e.g., "/**" or "/node_name")
          current_node_name = value;
          // Next will be MAPPING_START for this node's content
        } else if (state == ParseState::IN_NODE_CONTENT) {
          if (value == "ros__parameters") {
            // Next will be MAPPING_START for parameters
            state = ParseState::AWAITING_PARAMS_MAP;
          }
          // else: skip unknown keys (their values will be skipped too)
        } else if (state == ParseState::IN_PARAMS_MAP && map_depth == 1) {
          if (current_param_name.empty()) {
            // This is a parameter name
            current_param_name = value;
            state = ParseState::EXPECT_PARAM_VALUE;
          }
        } else if (state == ParseState::EXPECT_PARAM_VALUE) {
          // This is a parameter value
          // Check if this node name matches (/** matches all, or specific node name)
          bool matches = (current_node_name == "/**") ||
                         (current_node_name == get_fully_qualified_name()) ||
                         (current_node_name == "/" + node_name_);

          if (matches) {
            parameter_overrides_[current_param_name] = parse_parameter_value(value);
          }

          current_param_name.clear();
          state = ParseState::IN_PARAMS_MAP;
        }
        break;
      }

      default:
        break;
    }

    yaml_event_delete(&event);
  }

  yaml_parser_delete(&parser);
  fclose(file);

  return success;
}

rclcpp::CallbackGroup::SharedPtr Node::get_default_callback_group()
{
  return default_callback_group_;
}

bool Node::callback_group_in_node(const rclcpp::CallbackGroup::SharedPtr & group)
{
  // Check if the callback group belongs to this node
  // Corresponds to rclcpp::node_interfaces::NodeBase::callback_group_in_node
  for (auto & weak_group : callback_groups_) {
    auto shared_group = weak_group.lock();
    if (shared_group && shared_group == group) {
      return true;
    }
  }
  return false;
}

}  // namespace agnocast
