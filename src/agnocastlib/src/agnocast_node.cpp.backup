#include "agnocast/agnocast_node.hpp"
#include "agnocast/agnocast_context.hpp"

#include <algorithm>
#include <cctype>
#include <fstream>
#include <sstream>

#include <yaml.h>

namespace agnocast
{

Node::Node(const std::string & node_name, const std::string & ns)
: node_name_(node_name)
{
  // Normalize namespace (ensure it starts with '/' or is empty)
  if (!ns.empty() && ns[0] != '/') {
    namespace_ = "/" + ns;
  } else {
    namespace_ = ns;
  }

  // Get global arguments from GlobalContext
  // Corresponds to rclcpp::Node using context from NodeOptions
  apply_global_context();

  // Initialize default callback group
  default_callback_group_ =
    rclcpp::CallbackGroup::SharedPtr(new rclcpp::CallbackGroup(
      rclcpp::CallbackGroupType::MutuallyExclusive));
  callback_groups_.push_back(default_callback_group_);
}

std::string Node::get_fully_qualified_name() const
{
  // Corresponds to rcl_node_get_fully_qualified_name in rcl/src/rcl/node.c:453-459
  // Returns the fully qualified node name (namespace/node_name)
  // Example: namespace="/foo", node_name="bar" -> "/foo/bar"
  // Example: namespace="/", node_name="bar" -> "/bar"
  if (namespace_.empty() || namespace_ == "/") {
    return "/" + node_name_;
  }
  return namespace_ + "/" + node_name_;
}

std::string Node::resolve_topic_name(const std::string & input_topic_name) const
{
  // Corresponds to rcl_node_resolve_name in rcl/src/rcl/node_resolve_name.c:134-162
  return resolve_name(input_topic_name);
}

std::string Node::resolve_name(const std::string & input_topic_name) const
{
  // Corresponds to rcl_resolve_name in rcl/src/rcl/node_resolve_name.c:32-131
  // Variable names match rcl/src/rcl/node_resolve_name.c:57-58
  // Two-step process:
  // 1. Expand topic name (handle ~, {node}, {ns}, relative/absolute paths)
  // 2. Apply remapping rules (--ros-args -r old:=new)
  std::string expanded_topic_name = expand_topic_name(input_topic_name);
  std::string remapped_topic_name = remap_name(expanded_topic_name);
  return remapped_topic_name;
}

std::string Node::expand_topic_name(const std::string & input_topic_name) const
{
  // Corresponds to rcl_expand_topic_name in rcl/src/rcl/expand_topic_name.c:44-219
  // Handles:
  // - Private topics: "~foo" -> "/namespace/node_name/foo"
  // - Substitutions: "{node}" -> node_name, "{ns}" or "{namespace}" -> namespace
  // - Relative topics: "foo" -> "/namespace/foo"
  // - Absolute topics: "/foo" -> "/foo" (unchanged)

  if (input_topic_name.empty()) {
    return input_topic_name;
  }

  std::string local_output = input_topic_name;

  // Check for substitutions in the topic name
  // Variable names match rcl/src/rcl/expand_topic_name.c:97-100
  bool has_a_substitution = input_topic_name.find('{') != std::string::npos;
  bool has_a_namespace_tilde = !input_topic_name.empty() && input_topic_name[0] == '~';
  bool is_absolute = !input_topic_name.empty() && input_topic_name[0] == '/';

  // If absolute and no substitution, return as-is (rcl:102-110)
  if (is_absolute && !has_a_substitution) {
    return input_topic_name;
  }

  // Handle private topic name (starts with '~') (rcl:113-125)
  // Replace ~ with namespace/node_name
  if (has_a_namespace_tilde) {
    // Special case: namespace is "/" (rcl:117)
    if (namespace_.empty() || namespace_ == "/") {
      local_output = "/" + node_name_ + input_topic_name.substr(1);
    } else {
      local_output = namespace_ + "/" + node_name_ + input_topic_name.substr(1);
    }
  }

  // Handle substitutions ({node}, {ns}, {namespace}) (rcl:127-194)
  if (has_a_substitution) {
    size_t pos = 0;
    while ((pos = local_output.find('{', pos)) != std::string::npos) {
      size_t end_pos = local_output.find('}', pos);
      if (end_pos == std::string::npos) {
        break;  // Malformed substitution
      }

      std::string substitution = local_output.substr(pos, end_pos - pos + 1);
      std::string replacement;

      // rcl:144-150
      if (substitution == "{node}") {
        replacement = node_name_;
      } else if (substitution == "{ns}" || substitution == "{namespace}") {
        replacement = namespace_;
      }
      // Unknown substitutions are left as-is

      if (!replacement.empty()) {
        local_output.replace(pos, substitution.length(), replacement);
        pos += replacement.length();
      } else {
        pos = end_pos + 1;
      }
    }
  }

  // Make relative topic names absolute by prepending namespace (rcl:196-215)
  if (!local_output.empty() && local_output[0] != '/') {
    if (namespace_.empty() || namespace_ == "/") {
      local_output = "/" + local_output;
    } else {
      local_output = namespace_ + "/" + local_output;
    }
  }

  return local_output;
}

std::string Node::remap_name(const std::string & name) const
{
  // Corresponds to rcl_remap_name in rcl/src/rcl/remap.c:167-231
  // Variable names match rcl/src/rcl/remap.c:171 (name) and remap.c:129 (expanded_match)
  //
  // RCL expands the match side before comparing (remap.c:128-132)
  // Example: --ros-args -r foo:=/bar will map "foo" -> "/bar"
  // The "from" side is expanded before matching, so "foo" becomes "/namespace/foo"

  for (const auto & rule : remap_rules_) {
    // Only apply TOPIC remap rules (skip NODENAME and NAMESPACE)
    if (rule.type != RemapType::TOPIC) {
      continue;
    }

    // Expand the match side and compare
    std::string expanded_match = expand_topic_name(rule.match);
    if (expanded_match == name) {
      return rule.replacement;
    }
  }
  return name;
}

void Node::apply_global_context()
{
  // Corresponds to rclcpp::Node constructor merging global and local arguments
  // Get global arguments from GlobalContext and merge with local arguments

  auto & global_ctx = GlobalContext::instance();

  if (!global_ctx.is_initialized()) {
    // Global context not initialized, skip merging
    return;
  }

  // Merge global remap rules (global rules take precedence)
  // Insert global rules at the beginning
  auto global_rules = global_ctx.get_remap_rules();
  remap_rules_.insert(remap_rules_.begin(), global_rules.begin(), global_rules.end());

  // Merge global parameter overrides (local overrides take precedence)
  // Insert global parameters that don't exist locally
  auto global_params = global_ctx.get_parameter_overrides();
  for (const auto & [name, value] : global_params) {
    if (parameter_overrides_.find(name) == parameter_overrides_.end()) {
      parameter_overrides_[name] = value;
    }
  }

  // Apply node name and namespace remapping from global rules
  for (const auto & rule : global_rules) {
    if (rule.type == RemapType::NODENAME) {
      node_name_ = rule.replacement;
    } else if (rule.type == RemapType::NAMESPACE) {
      namespace_ = rule.replacement;
    }
  }
}

void Node::parse_ros_args(int argc, char * argv[])
{
  // Corresponds to rcl_parse_arguments in rcl/src/rcl/arguments.c:317-428
  // Parses ROS 2 command-line arguments:
  // - --ros-args: Start of ROS arguments section
  // - -r name:=value: Topic/service remapping
  // - -p name:=value: Parameter setting
  // - --params-file path: Load parameters from YAML file
  // - --: End of ROS arguments section
  // Example: ./node --ros-args -r foo:=/bar -p my_param:=42 --
  //
  // Two-pass parsing:
  // 1. First pass: Apply remapping rules (to get correct node name/namespace)
  // 2. Second pass: Load parameter files and -p parameters
  //    (now that node name is finalized for matching YAML sections)

  std::vector<std::string> param_files;
  std::vector<std::string> param_rules;
  bool in_ros_args = false;

  // First pass: collect everything and apply remapping immediately
  for (int i = 1; i < argc; ++i) {
    std::string arg = argv[i];

    // Check for --ros-args flag (rcl:318-329)
    if (arg == "--ros-args") {
      in_ros_args = true;
      continue;
    }

    if (!in_ros_args) {
      continue;
    }

    // End of ROS args with -- token (rcl:318-329)
    if (arg == "--") {
      break;
    }

    // Parse remapping: -r name:=value (rcl:395-415)
    // Apply immediately to set correct node name/namespace
    if (arg == "-r" && i + 1 < argc) {
      std::string remap_arg = argv[++i];
      parse_remap_rule(remap_arg);
      continue;
    }

    // Collect parameter rules for second pass
    if (arg == "-p" && i + 1 < argc) {
      param_rules.push_back(argv[++i]);
      continue;
    }

    // Collect parameter files for second pass
    if (arg == "--params-file" && i + 1 < argc) {
      param_files.push_back(argv[++i]);
      continue;
    }
  }

  // Second pass: load parameter files (node name is now finalized)
  for (const auto & file_path : param_files) {
    load_parameters_from_yaml_file(file_path);
  }

  // Second pass: apply -p parameters (these override file parameters)
  for (const auto & param_arg : param_rules) {
    parse_param_rule(param_arg);
  }
}

bool Node::parse_remap_rule(const std::string & arg)
{
  // Corresponds to _rcl_parse_remap_rule in rcl/src/rcl/arguments.c:1827-1873
  //
  // Parses remapping rules in the form "from:=to"
  // - "__ns:=/namespace"      -> Namespace remapping
  // - "__node:=name"          -> Node name remapping
  // - "topic:=/new_topic"     -> Topic remapping
  //
  // RCL implementation flow (simplified for agnocast):
  // 1. Split on := separator
  // 2. Determine rule type (__node, __ns, or topic) at line 1647-1663
  // 3. Store rule for later application

  // Step 1: Split on := separator
  size_t separator = arg.find(":=");

  if (separator == std::string::npos) {
    return false;
  }

  std::string from = arg.substr(0, separator);
  std::string to = arg.substr(separator + 2);

  // Step 2: Determine rule type (corresponds to rcl:1647-1663)
  RemapRule rule;
  rule.match = from;
  rule.replacement = to;

  if (from == "__node" || from == "__name") {
    // Node name remapping (rcl:1648-1652)
    rule.type = RemapType::NODENAME;
  } else if (from == "__ns") {
    // Namespace remapping (rcl:1653-1657)
    rule.type = RemapType::NAMESPACE;
    // Normalize namespace: ensure it starts with '/'
    if (!rule.replacement.empty() && rule.replacement[0] != '/') {
      rule.replacement = "/" + rule.replacement;
    }
  } else {
    // Topic/service remapping (rcl:1659-1662)
    rule.type = RemapType::TOPIC;
  }

  // Step 3: Apply rule immediately if it affects node configuration
  // (namespace and node name must be set during initialization)
  if (rule.type == RemapType::NODENAME) {
    node_name_ = to;
  } else if (rule.type == RemapType::NAMESPACE) {
    namespace_ = rule.replacement;
  }

  // Store the rule for later application in remap_name()
  remap_rules_.push_back(rule);
  return true;
}

bool Node::parse_param_rule(const std::string & arg)
{
  // Corresponds to _rcl_parse_param_rule in rcl/src/rcl/arguments.c:1876-1950
  // Variable names match rcl/src/rcl/arguments.c:1893 (param_name) and 1933 (yaml_value)
  // Parses parameter rules in the form "name:=value"
  // Example: my_param:=42, debug:=true, name:=hello
  size_t delim_pos = arg.find(":=");

  if (delim_pos == std::string::npos) {
    return false;
  }

  std::string param_name = arg.substr(0, delim_pos);
  std::string yaml_value = arg.substr(delim_pos + 2);

  // Parse YAML value (rcl:1933-1937 calls rcl_parse_yaml_value)
  parameter_overrides_[param_name] = parse_parameter_value(yaml_value);
  return true;
}

Node::ParameterValue Node::parse_parameter_value(const std::string & value_str) const
{
  // Corresponds to rcl_parse_yaml_value in rcl_yaml_param_parser/src/parser.c
  // Performs type inference in this order:
  // 1. Boolean: "true", "True", "TRUE", "false", "False", "FALSE"
  // 2. Integer: valid int64_t (e.g., "42", "-10")
  // 3. Double: valid double (e.g., "3.14", "1.0")
  // 4. String: anything else (e.g., "hello")

  // Try to parse as bool
  if (value_str == "true" || value_str == "True" || value_str == "TRUE") {
    return true;
  }
  if (value_str == "false" || value_str == "False" || value_str == "FALSE") {
    return false;
  }

  // Try to parse as integer
  try {
    size_t pos = 0;
    int64_t int_value = std::stoll(value_str, &pos);
    if (pos == value_str.length()) {
      return int_value;
    }
  } catch (...) {
  }

  // Try to parse as double
  try {
    size_t pos = 0;
    double double_value = std::stod(value_str, &pos);
    if (pos == value_str.length()) {
      return double_value;
    }
  } catch (...) {
  }

  // Default to string
  return value_str;
}

const Node::ParameterValue & Node::declare_parameter(
  const std::string & name,
  const ParameterValue & default_value,
  const ParameterDescriptor & descriptor,
  bool ignore_override)
{
  // Corresponds to NodeParameters::declare_parameter in
  // rclcpp/src/rclcpp/node_interfaces/node_parameters.cpp

  // Check if parameter already exists
  if (parameters_.find(name) != parameters_.end()) {
    // Parameter already declared, return existing value
    return parameters_[name].value;
  }

  ParameterInfo param_info;
  param_info.descriptor = descriptor;

  // Check for command-line override (unless ignore_override is true)
  if (!ignore_override && parameter_overrides_.find(name) != parameter_overrides_.end()) {
    param_info.value = parameter_overrides_[name];
  } else {
    param_info.value = default_value;
  }

  parameters_[name] = param_info;
  return parameters_[name].value;
}

bool Node::has_parameter(const std::string & name) const
{
  // Corresponds to NodeParameters::has_parameter in
  // rclcpp/include/rclcpp/node_interfaces/node_parameters.hpp:130
  return parameters_.find(name) != parameters_.end();
}

std::vector<uint8_t> Node::get_parameter_types(const std::vector<std::string> & names) const
{
  // Corresponds to NodeParameters::get_parameter_types in
  // rclcpp/src/rclcpp/node_interfaces/node_parameters.cpp:896-919

  std::vector<uint8_t> types;
  types.reserve(names.size());

  for (const auto & name : names) {
    auto it = parameters_.find(name);
    if (it != parameters_.end()) {
      // Determine type from variant index
      const auto & value = it->second.value;
      if (std::holds_alternative<bool>(value)) {
        types.push_back(PARAMETER_BOOL);
      } else if (std::holds_alternative<int64_t>(value)) {
        types.push_back(PARAMETER_INTEGER);
      } else if (std::holds_alternative<double>(value)) {
        types.push_back(PARAMETER_DOUBLE);
      } else if (std::holds_alternative<std::string>(value)) {
        types.push_back(PARAMETER_STRING);
      } else {
        types.push_back(PARAMETER_NOT_SET);
      }
    } else {
      types.push_back(PARAMETER_NOT_SET);
    }
  }

  return types;
}

bool Node::get_parameter(const std::string & name, bool & value) const
{
  // Corresponds to NodeParameters::get_parameter in
  // rclcpp/src/rclcpp/node_interfaces/node_parameters.cpp:829-845

  auto it = parameters_.find(name);
  if (it == parameters_.end()) {
    return false;
  }

  if (auto * v = std::get_if<bool>(&it->second.value)) {
    value = *v;
    return true;
  }
  return false;
}

bool Node::get_parameter(const std::string & name, int64_t & value) const
{
  auto it = parameters_.find(name);
  if (it == parameters_.end()) {
    return false;
  }

  if (auto * v = std::get_if<int64_t>(&it->second.value)) {
    value = *v;
    return true;
  }
  return false;
}

